# Copy this file to .env and fill in the token from `claude setup-token`.
# Keep .env private. Do not commit the real token.
CLAUDE_OAUTH_TOKEN=sk-ant-oat01-replace-this-with-your-token

# The prompt should stay tiny. It only needs to reach Claude Code.
CLAUDE_WARMUP_PROMPT="Reply with exactly: ok"

# Haiku keeps the warmup request small.
CLAUDE_WARMUP_MODEL=haiku
